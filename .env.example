# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""
# Optional: keep previous secrets for JWT decryption during secret rotation
AUTH_SECRET_1=""
AUTH_SECRET_2=""
AUTH_SECRET_3=""
# Legacy alias, kept for backwards compatibility
NEXTAUTH_SECRET=""

# Next Auth WeChat Provider
AUTH_WECHAT_ID=""
AUTH_WECHAT_SECRET=""

# Next Auth QQ Provider
AUTH_QQ_ID=""
AUTH_QQ_SECRET=""

# Next Auth Local Credentials Provider (default: admin / admin123456)
AUTH_CREDENTIALS_USERNAME="admin"
AUTH_CREDENTIALS_PASSWORD="admin123456"

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
# If you run PostgreSQL through `deploy/docker-compose.yml`, keep this URL in sync
# with `deploy/.env`. For example, when Docker exposes PostgreSQL on port 5435
# and `POSTGRES_PASSWORD=your-password`, use:
# DATABASE_URL="postgresql://postgres:your-password@localhost:5435/stock-screening-boost"
DATABASE_URL="postgresql://postgres:password@localhost:5432/stock-screening-boost"

# Workflow Runtime
REDIS_URL="redis://127.0.0.1:6379"
PYTHON_SERVICE_URL="http://127.0.0.1:8000"
PYTHON_SERVICE_TIMEOUT_MS="60000"
PYTHON_INTELLIGENCE_SERVICE_URL="http://127.0.0.1:8000"
PYTHON_INTELLIGENCE_SERVICE_TIMEOUT_MS="30000"
IFIND_USERNAME=""
IFIND_PASSWORD=""
SCREENING_PRIMARY_PROVIDER="ifind"
SCREENING_ENABLE_AKSHARE_FALLBACK="true"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
FIRECRAWL_API_KEY=""
FIRECRAWL_BASE_URL="https://api.firecrawl.dev"
FIRECRAWL_TIMEOUT_MS="15000"
WORKFLOW_WORKER_POLL_INTERVAL_MS="2000"
SCREENING_WORKER_POLL_INTERVAL_MS="2000"
REFCHECKER_ENABLED="false"
REFCHECKER_MODEL=""
REFCHECKER_API_BASE=""
REFCHECKER_TIMEOUT_SECONDS="20"
REFCHECKER_BATCH_SIZE="4"
