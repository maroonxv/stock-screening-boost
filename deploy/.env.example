# Docker Compose project name
COMPOSE_PROJECT_NAME=stock-screening-boost

# Host ports (Windows + WSL both use localhost access)
WEB_PORT=3000
PYTHON_SERVICE_PORT=8000
POSTGRES_PORT=5432

# Postgres
# `POSTGRES_PASSWORD` is only applied when the database volume is initialized the
# first time. If you change it later, also recreate the `postgres_data` volume or
# run `ALTER USER postgres WITH PASSWORD 'new-password';` inside PostgreSQL.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=stock-screening-boost

# NextAuth / Auth.js
# Generate with: npx auth secret
# Must be a real value before the containers start.
# Docker Compose starts the Node services with NODE_ENV=production,
# so even local Docker deployments need a real secret with at least 32 characters.
AUTH_SECRET=
# Optional: keep previous secrets for JWT decryption during secret rotation,
# for example when moving from local dev to Docker or rotating production secrets.
AUTH_SECRET_1=
AUTH_SECRET_2=
AUTH_SECRET_3=
# Legacy alias, kept for backwards compatibility
# Keep this equal to AUTH_SECRET when you still need the legacy variable.
NEXTAUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Optional WeChat OAuth provider
AUTH_WECHAT_ID=
AUTH_WECHAT_SECRET=

# Optional QQ OAuth provider
AUTH_QQ_ID=
AUTH_QQ_SECRET=

# Local credentials provider (fallback)
AUTH_CREDENTIALS_USERNAME=admin
AUTH_CREDENTIALS_PASSWORD=admin123456

# Runtime service endpoints (inside docker network)
REDIS_URL=redis://redis:6379
PYTHON_SERVICE_URL=http://python-service:8000
PYTHON_INTELLIGENCE_SERVICE_URL=http://python-service:8000
PYTHON_INTELLIGENCE_SERVICE_TIMEOUT_MS=300000

# DeepSeek (used by both `web` and `workflow-worker`)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_MS=15000
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_TIMEOUT_MS=15000
WORKFLOW_WORKER_POLL_INTERVAL_MS=2000

# Screening provider
IFIND_USERNAME=
IFIND_PASSWORD=
SCREENING_PRIMARY_PROVIDER=ifind
SCREENING_ENABLE_AKSHARE_FALLBACK=true

# Screening worker
SCREENING_WORKER_POLL_INTERVAL_MS=2000

# Python service CORS + cache
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
INTELLIGENCE_CACHE_TTL_SECONDS=300
INTELLIGENCE_CACHE_STALE_SECONDS=1800
INTELLIGENCE_SPOT_CACHE_TTL_SECONDS=120
INTELLIGENCE_ENABLE_MOCK_FALLBACK=true

# Python service advanced intelligence capabilities
# Set to the Redis instance used by the Python gateway L2 cache.
# In Docker Compose this is usually the built-in redis service.
GATEWAY_REDIS_URL=redis://redis:6379
GATEWAY_REDIS_PREFIX=gateway-cache
GATEWAY_HOT_THEMES=AI,算力,机器人

# Optional Zhipu Web Search integration for theme -> concept mapping
ZHIPU_API_KEY=
ZHIPU_WEB_SEARCH_MODEL=glm-4-plus
ZHIPU_WEB_SEARCH_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions
ZHIPU_WEB_SEARCH_TIMEOUT_SECONDS=8
ZHIPU_WEB_SEARCH_RETRIES=2

# RefChecker confidence analysis
# When set to true, `docker compose up --build` will also install the optional
# RefChecker dependency set into the python-service image. Keep this false if
# you only need the default heuristic fallback.
REFCHECKER_ENABLED=false
REFCHECKER_MODEL=
REFCHECKER_API_BASE=
REFCHECKER_TIMEOUT_SECONDS=20
REFCHECKER_BATCH_SIZE=4

# Optional: override the THS concept catalog snapshot path inside the python-service container.
# The compose default bind-mounts the repo data directory to /app/data.
INTELLIGENCE_CONCEPT_CATALOG_FILE=/app/data/ths_concept_catalog.csv

# Optional: override the persisted rules file path inside the python-service container.
# The compose default stores it in the named volume mounted at /data/theme-concept-rules.
INTELLIGENCE_THEME_CONCEPT_RULES_FILE=/data/theme-concept-rules/theme_concept_rules.json
