@startuml
!theme materia
skinparam defaultFontColor #FFFFFF
skinparam ArrowColor #FFFFFF
skinparam LineColor #FFFFFF
skinparam PackageBorderColor #FFFFFF
skinparam RectangleBorderColor #FFFFFF
skinparam ComponentBorderColor #FFFFFF
skinparam SequenceArrowColor #FFFFFF
skinparam SequenceLifeLineBorderColor #FFFFFF
skinparam SequenceParticipantBorderColor #FFFFFF
skinparam SequenceParticipantFontColor #FFFFFF
skinparam ActivityBorderColor #FFFFFF
skinparam ActivityFontColor #FFFFFF
skinparam ActivityDiamondBorderColor #FFFFFF
skinparam ActivityDiamondFontColor #FFFFFF
skinparam StateBorderColor #FFFFFF
skinparam StateFontColor #FFFFFF
title 数据/依赖流图
skinparam shadowing false

rectangle "timingCards\nactionBias / confidence / signalContext" as Cards
rectangle "portfolioSnapshot.positions" as Positions
rectangle "riskPlan\nblockedActions / budget" as RiskPlan
rectangle "marketContextAnalysis" as Market
rectangle "feedbackContext" as Feedback
rectangle "Candidate\nnormalized action / pct range / score / riskFlags" as Candidate
rectangle "budgeted Candidate" as Budgeted
rectangle "TimingRecommendationDraft\npriority / reasoning / pct range" as Recommendation

Cards --> Candidate
Positions --> Candidate
RiskPlan --> Candidate
Market --> Candidate
Feedback --> Candidate
Candidate --> Budgeted : remainingRiskBudget 截断
Budgeted --> Recommendation
@enduml
