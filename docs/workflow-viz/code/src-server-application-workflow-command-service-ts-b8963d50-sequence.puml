@startuml
!theme materia
skinparam defaultFontColor #FFFFFF
skinparam ArrowColor #FFFFFF
skinparam LineColor #FFFFFF
skinparam PackageBorderColor #FFFFFF
skinparam RectangleBorderColor #FFFFFF
skinparam ComponentBorderColor #FFFFFF
skinparam SequenceArrowColor #FFFFFF
skinparam SequenceLifeLineBorderColor #FFFFFF
skinparam SequenceParticipantBorderColor #FFFFFF
skinparam SequenceParticipantFontColor #FFFFFF
skinparam ActivityBorderColor #FFFFFF
skinparam ActivityFontColor #FFFFFF
skinparam ActivityDiamondBorderColor #FFFFFF
skinparam ActivityDiamondFontColor #FFFFFF
skinparam StateBorderColor #FFFFFF
skinparam StateFontColor #FFFFFF
title 协作顺序图
autonumber

actor "workflowRouter" as Router
participant "WorkflowCommandService" as Service
participant "PrismaWorkflowRunRepository" as Repository

Router -> Service : startWatchlistTimingPipeline(command)
Service -> Service : 组装 query / input / idempotencyKey
Service -> Repository : findPendingOrRunningByIdempotency()
alt 命中已有 run
  Repository --> Service : existing run
  Service --> Router : 直接返回 existing runId
else 创建新 run
  Service -> Repository : getTemplateByCodeAndVersion()
  alt 模板缺失
    Service -> Repository : ensureWatchlistTimingPipelineTemplate()
  end
  Service -> Repository : createRun(nodeKeys, input, query)
  Repository --> Service : run
  Service --> Router : runId / status / createdAt
end
@enduml
