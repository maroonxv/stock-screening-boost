@startuml
!theme materia
skinparam defaultFontColor #FFFFFF
skinparam ArrowColor #FFFFFF
skinparam LineColor #FFFFFF
skinparam PackageBorderColor #FFFFFF
skinparam RectangleBorderColor #FFFFFF
skinparam ComponentBorderColor #FFFFFF
skinparam SequenceArrowColor #FFFFFF
skinparam SequenceLifeLineBorderColor #FFFFFF
skinparam SequenceParticipantBorderColor #FFFFFF
skinparam SequenceParticipantFontColor #FFFFFF
skinparam ActivityBorderColor #FFFFFF
skinparam ActivityFontColor #FFFFFF
skinparam ActivityDiamondBorderColor #FFFFFF
skinparam ActivityDiamondFontColor #FFFFFF
skinparam StateBorderColor #FFFFFF
skinparam StateFontColor #FFFFFF
title 主流程活动图
start
:load_watchlist_context\n读取 watchlist / snapshot / preset;
if (watchlist 或 snapshot 缺失?) then (是)
  :抛出错误并终止 run;
  stop
endif

:fetch_signal_snapshots_batch\n批量拉取 signalSnapshots;
if (targets 为空?) then (是)
  :返回空 signalSnapshots;
else (否)
  if (批量接口只返回 errors?) then (是)
    :抛出错误并终止 run;
    stop
  endif
endif

:technical_signal_agent\n生成 technicalAssessments;
:timing_synthesis_agent\n生成 timing cards;

if (命中市场语境缓存?) then (是)
  :复用已有 marketContextAnalysis;
else (否)
  :拉取市场快照并分析 regime;
  :upsert 市场语境缓存;
endif

:watchlist_risk_manager\n生成 riskPlan;
:watchlist_portfolio_manager\n读取 feedbackContext 并生成 recommendations;
:persist_recommendations\n落库建议并安排复盘提醒;
stop
@enduml
