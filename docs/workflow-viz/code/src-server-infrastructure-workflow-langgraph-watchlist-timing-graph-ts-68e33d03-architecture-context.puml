@startuml
!theme materia
skinparam defaultFontColor #FFFFFF
skinparam ArrowColor #FFFFFF
skinparam LineColor #FFFFFF
skinparam PackageBorderColor #FFFFFF
skinparam RectangleBorderColor #FFFFFF
skinparam ComponentBorderColor #FFFFFF
skinparam SequenceArrowColor #FFFFFF
skinparam SequenceLifeLineBorderColor #FFFFFF
skinparam SequenceParticipantBorderColor #FFFFFF
skinparam SequenceParticipantFontColor #FFFFFF
skinparam ActivityBorderColor #FFFFFF
skinparam ActivityFontColor #FFFFFF
skinparam ActivityDiamondBorderColor #FFFFFF
skinparam ActivityDiamondFontColor #FFFFFF
skinparam StateBorderColor #FFFFFF
skinparam StateFontColor #FFFFFF
title 架构总览图
skinparam shadowing false
skinparam componentStyle rectangle

actor "工作流执行器" as Runner
rectangle "WatchlistTimingPipelineLangGraph" as Graph
rectangle "PrismaWatchListRepository" as WatchListRepo
rectangle "PrismaPortfolioSnapshotRepository" as SnapshotRepo
rectangle "PrismaTimingPresetRepository" as PresetRepo
rectangle "PythonTimingDataClient" as TimingDataClient
rectangle "TimingAnalysisService" as AnalysisService
rectangle "PrismaTimingMarketContextSnapshotRepository" as MarketRepo
rectangle "MarketRegimeService" as MarketRegimeService
rectangle "WatchlistRiskManagerService" as RiskManager
rectangle "TimingFeedbackService" as FeedbackService
rectangle "WatchlistPortfolioManagerService" as PortfolioManager
rectangle "PrismaTimingRecommendationRepository" as RecommendationRepo
rectangle "TimingReviewSchedulingService" as ReviewService

Runner --> Graph : 按节点顺序执行 run
Graph --> WatchListRepo : 读取自选股上下文
Graph --> SnapshotRepo : 读取组合快照
Graph --> PresetRepo : 读取择时预设
Graph --> TimingDataClient : 拉取批量信号 / 市场快照
Graph --> AnalysisService : 生成 assessment / timing cards
Graph --> MarketRepo : 复用或缓存市场语境
Graph --> MarketRegimeService : 分析市场状态
Graph --> RiskManager : 生成 riskPlan
Graph --> FeedbackService : 读取 feedbackContext
Graph --> PortfolioManager : 生成组合建议
Graph --> RecommendationRepo : 持久化 recommendations
Graph --> ReviewService : 安排复盘记录与提醒
@enduml
