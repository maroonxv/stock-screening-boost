@startuml
!theme materia
skinparam defaultFontColor #FFFFFF
skinparam ArrowColor #FFFFFF
skinparam LineColor #FFFFFF
skinparam PackageBorderColor #FFFFFF
skinparam RectangleBorderColor #FFFFFF
skinparam ComponentBorderColor #FFFFFF
skinparam SequenceArrowColor #FFFFFF
skinparam SequenceLifeLineBorderColor #FFFFFF
skinparam SequenceParticipantBorderColor #FFFFFF
skinparam SequenceParticipantFontColor #FFFFFF
skinparam ActivityBorderColor #FFFFFF
skinparam ActivityFontColor #FFFFFF
skinparam ActivityDiamondBorderColor #FFFFFF
skinparam ActivityDiamondFontColor #FFFFFF
skinparam StateBorderColor #FFFFFF
skinparam StateFontColor #FFFFFF
title 依赖职责图
skinparam shadowing false
skinparam componentStyle rectangle

rectangle "WatchlistTimingPipelineLangGraph" as Graph

package "仓储依赖" {
  rectangle "WatchListRepository" as WatchRepo
  rectangle "PortfolioSnapshotRepository" as SnapshotRepo
  rectangle "TimingPresetRepository" as PresetRepo
  rectangle "MarketContextSnapshotRepository" as MarketRepo
  rectangle "TimingRecommendationRepository" as RecommendationRepo
}

package "数据与分析依赖" {
  rectangle "PythonTimingDataClient" as DataClient
  rectangle "TimingAnalysisService" as AnalysisService
  rectangle "MarketRegimeService" as RegimeService
}

package "组合与复盘依赖" {
  rectangle "WatchlistRiskManagerService" as RiskManager
  rectangle "TimingFeedbackService" as FeedbackService
  rectangle "WatchlistPortfolioManagerService" as PortfolioManager
  rectangle "TimingReviewSchedulingService" as ReviewService
}

Graph --> WatchRepo : watchlist / targets
Graph --> SnapshotRepo : portfolioSnapshot
Graph --> PresetRepo : presetConfig
Graph --> DataClient : signalSnapshots / marketContextSnapshot
Graph --> AnalysisService : technicalAssessments / cards
Graph --> MarketRepo : 复用缓存 / upsert analysis
Graph --> RegimeService : marketContextAnalysis
Graph --> RiskManager : riskPlan
Graph --> FeedbackService : feedbackContext
Graph --> PortfolioManager : recommendations
Graph --> RecommendationRepo : persistedRecommendations
Graph --> ReviewService : reviewRecords / reminderIds
@enduml
