@startuml
!theme materia
skinparam defaultFontColor #FFFFFF
skinparam ArrowColor #FFFFFF
skinparam LineColor #FFFFFF
skinparam PackageBorderColor #FFFFFF
skinparam RectangleBorderColor #FFFFFF
skinparam ComponentBorderColor #FFFFFF
skinparam SequenceArrowColor #FFFFFF
skinparam SequenceLifeLineBorderColor #FFFFFF
skinparam SequenceParticipantBorderColor #FFFFFF
skinparam SequenceParticipantFontColor #FFFFFF
skinparam ActivityBorderColor #FFFFFF
skinparam ActivityFontColor #FFFFFF
skinparam ActivityDiamondBorderColor #FFFFFF
skinparam ActivityDiamondFontColor #FFFFFF
skinparam StateBorderColor #FFFFFF
skinparam StateFontColor #FFFFFF
title 模块拆解图
skinparam shadowing false
skinparam componentStyle rectangle

package "LangGraph 内部职责" {
  component "输入装载\nload_watchlist_context" as LoadContext
  component "批量信号阶段\nfetch_signal_snapshots_batch\ntechnical_signal_agent\ntiming_synthesis_agent" as SignalStage
  component "市场语境阶段\nmarket_regime_agent" as MarketStage
  component "组合决策阶段\nwatchlist_risk_manager\nwatchlist_portfolio_manager" as PortfolioStage
  component "产物落库阶段\npersist_recommendations" as PersistStage
}

LoadContext --> SignalStage : targets / presetConfig
SignalStage --> MarketStage : cards
MarketStage --> PortfolioStage : marketContextAnalysis
PortfolioStage --> PersistStage : recommendations
PersistStage --> LoadContext : 供后续 run 查询结果
@enduml
