@startuml
!theme materia
skinparam defaultFontColor #FFFFFF
skinparam ArrowColor #FFFFFF
skinparam LineColor #FFFFFF
skinparam PackageBorderColor #FFFFFF
skinparam RectangleBorderColor #FFFFFF
skinparam ComponentBorderColor #FFFFFF
skinparam SequenceArrowColor #FFFFFF
skinparam SequenceLifeLineBorderColor #FFFFFF
skinparam SequenceParticipantBorderColor #FFFFFF
skinparam SequenceParticipantFontColor #FFFFFF
skinparam ActivityBorderColor #FFFFFF
skinparam ActivityFontColor #FFFFFF
skinparam ActivityDiamondBorderColor #FFFFFF
skinparam ActivityDiamondFontColor #FFFFFF
skinparam StateBorderColor #FFFFFF
skinparam StateFontColor #FFFFFF
title 异步/并发图
autonumber

participant "LangGraph" as Graph
participant "WatchListRepo" as WatchRepo
participant "SnapshotRepo" as SnapshotRepo
participant "PresetRepo" as PresetRepo
participant "TimingFeedbackService" as FeedbackService
participant "SuggestionRepo" as SuggestionRepo

Graph -> Graph : load_watchlist_context()
par 读取 watchlist
  Graph -> WatchRepo : findById()
else 读取 portfolioSnapshot
  Graph -> SnapshotRepo : getByIdForUser()
else 读取 preset
  Graph -> PresetRepo : getByIdForUser()
end

Graph -> Graph : watchlist_portfolio_manager()
Graph -> FeedbackService : buildContext()
activate FeedbackService
par 查询 pending suggestions
  FeedbackService -> SuggestionRepo : listForUser(status=PENDING)
else 查询 applied suggestions
  FeedbackService -> SuggestionRepo : listForUser(status=APPLIED)
end
SuggestionRepo --> FeedbackService : suggestion batches
FeedbackService --> Graph : feedbackContext
deactivate FeedbackService
@enduml
