@startuml
!theme materia
skinparam defaultFontColor #FFFFFF
skinparam ArrowColor #FFFFFF
skinparam LineColor #FFFFFF
skinparam PackageBorderColor #FFFFFF
skinparam RectangleBorderColor #FFFFFF
skinparam ComponentBorderColor #FFFFFF
skinparam SequenceArrowColor #FFFFFF
skinparam SequenceLifeLineBorderColor #FFFFFF
skinparam SequenceParticipantBorderColor #FFFFFF
skinparam SequenceParticipantFontColor #FFFFFF
skinparam ActivityBorderColor #FFFFFF
skinparam ActivityFontColor #FFFFFF
skinparam ActivityDiamondBorderColor #FFFFFF
skinparam ActivityDiamondFontColor #FFFFFF
skinparam StateBorderColor #FFFFFF
skinparam StateFontColor #FFFFFF
title 数据/依赖流图
skinparam shadowing false

rectangle "timingInput\nwatchListId / portfolioSnapshotId / presetId / asOfDate" as Input
rectangle "load_watchlist_context\nwatchlist / portfolioSnapshot / targets / presetConfig" as Context
rectangle "fetch_signal_snapshots_batch\nsignalSnapshots" as Snapshots
rectangle "technical_signal_agent + timing_synthesis_agent\ntechnicalAssessments / cards" as Cards
rectangle "market_regime_agent\nmarketContextAnalysis" as Market
rectangle "watchlist_risk_manager\nriskPlan" as RiskPlan
rectangle "watchlist_portfolio_manager\nfeedbackContext + recommendations" as Recommendations
rectangle "persist_recommendations\npersistedRecommendations / reviewRecords / reminderIds" as Persisted

Input --> Context
Context --> Snapshots
Snapshots --> Cards
Cards --> Market
Cards --> RiskPlan
Market --> RiskPlan
Cards --> Recommendations
Market --> Recommendations
RiskPlan --> Recommendations
Recommendations --> Persisted
@enduml
