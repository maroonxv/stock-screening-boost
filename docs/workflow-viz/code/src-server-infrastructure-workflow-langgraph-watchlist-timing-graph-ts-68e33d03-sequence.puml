@startuml
!theme materia
skinparam defaultFontColor #FFFFFF
skinparam ArrowColor #FFFFFF
skinparam LineColor #FFFFFF
skinparam PackageBorderColor #FFFFFF
skinparam RectangleBorderColor #FFFFFF
skinparam ComponentBorderColor #FFFFFF
skinparam SequenceArrowColor #FFFFFF
skinparam SequenceLifeLineBorderColor #FFFFFF
skinparam SequenceParticipantBorderColor #FFFFFF
skinparam SequenceParticipantFontColor #FFFFFF
skinparam ActivityBorderColor #FFFFFF
skinparam ActivityFontColor #FFFFFF
skinparam ActivityDiamondBorderColor #FFFFFF
skinparam ActivityDiamondFontColor #FFFFFF
skinparam StateBorderColor #FFFFFF
skinparam StateFontColor #FFFFFF
title 协作顺序图
autonumber

actor "WorkflowRunner" as Runner
participant "WatchlistTimingPipelineLangGraph" as Graph
participant "WatchListRepo / SnapshotRepo / PresetRepo" as ContextRepos
participant "PythonTimingDataClient" as DataClient
participant "TimingAnalysisService" as AnalysisService
participant "MarketRepo + MarketRegimeService" as MarketServices
participant "WatchlistRiskManagerService" as RiskManager
participant "TimingFeedbackService" as FeedbackService
participant "WatchlistPortfolioManagerService" as PortfolioManager
participant "RecommendationRepo + ReviewService" as PersistServices

Runner -> Graph : 执行 watchlist timing run
Graph -> ContextRepos : load_watchlist_context()
ContextRepos --> Graph : watchlist / snapshot / preset
Graph -> DataClient : getSignalsBatch()
DataClient --> Graph : signalSnapshots / batchErrors
Graph -> AnalysisService : buildTechnicalAssessments() / buildCards()
AnalysisService --> Graph : technicalAssessments / cards
Graph -> MarketServices : 复用或生成 marketContextAnalysis
MarketServices --> Graph : marketContextAnalysis
Graph -> RiskManager : buildRiskPlan()
RiskManager --> Graph : riskPlan
Graph -> FeedbackService : buildContext()
FeedbackService --> Graph : feedbackContext
Graph -> PortfolioManager : buildRecommendations()
PortfolioManager --> Graph : recommendations
Graph -> PersistServices : createMany() + scheduleForRecommendations()
PersistServices --> Graph : persistedRecommendations / reviewRecords / reminderIds
Graph --> Runner : 更新 state 并完成 run
@enduml
