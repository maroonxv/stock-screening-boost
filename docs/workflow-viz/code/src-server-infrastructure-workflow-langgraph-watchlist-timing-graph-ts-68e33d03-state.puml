@startuml
!theme materia
skinparam defaultFontColor #FFFFFF
skinparam ArrowColor #FFFFFF
skinparam LineColor #FFFFFF
skinparam PackageBorderColor #FFFFFF
skinparam RectangleBorderColor #FFFFFF
skinparam ComponentBorderColor #FFFFFF
skinparam SequenceArrowColor #FFFFFF
skinparam SequenceLifeLineBorderColor #FFFFFF
skinparam SequenceParticipantBorderColor #FFFFFF
skinparam SequenceParticipantFontColor #FFFFFF
skinparam ActivityBorderColor #FFFFFF
skinparam ActivityFontColor #FFFFFF
skinparam ActivityDiamondBorderColor #FFFFFF
skinparam ActivityDiamondFontColor #FFFFFF
skinparam StateBorderColor #FFFFFF
skinparam StateFontColor #FFFFFF
title 状态图
[*] --> load_watchlist_context
load_watchlist_context : preset / watchlist / portfolioSnapshot / targets
load_watchlist_context --> fetch_signal_snapshots_batch
fetch_signal_snapshots_batch : signalSnapshots / batchErrors
fetch_signal_snapshots_batch --> technical_signal_agent
technical_signal_agent : technicalAssessments
technical_signal_agent --> timing_synthesis_agent
timing_synthesis_agent : cards
timing_synthesis_agent --> market_regime_agent
market_regime_agent : marketContextSnapshot / marketContextAnalysis
market_regime_agent --> watchlist_risk_manager
watchlist_risk_manager : riskPlan
watchlist_risk_manager --> watchlist_portfolio_manager
watchlist_portfolio_manager : feedbackContext / recommendations
watchlist_portfolio_manager --> persist_recommendations
persist_recommendations : persistedRecommendations / reviewRecords / reminderIds
persist_recommendations --> [*]
@enduml
