@startuml
!theme materia
title 异步/并发图
autonumber

participant "触发方" as Trigger
participant "热点文件入口" as Workflow
participant "异步执行单元" as Worker

Trigger -> Workflow : 发起异步任务
activate Workflow
Workflow -> Worker : 分派并发动作
activate Worker
Worker --> Workflow : 回传结果或信号
deactivate Worker
Workflow --> Trigger : 返回确认结果
deactivate Workflow
@enduml
