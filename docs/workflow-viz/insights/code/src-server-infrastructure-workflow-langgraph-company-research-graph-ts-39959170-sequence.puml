@startuml
!theme materia
title 协作顺序图
autonumber

actor "发起方" as Caller
participant "热点文件入口" as Entry
participant "关键协作者甲" as DepA
participant "关键协作者乙" as DepB

Caller -> Entry : 发起调用
Entry -> DepA : 请求步骤一
DepA --> Entry : 返回阶段结果
Entry -> DepB : 请求步骤二
DepB --> Entry : 返回阶段结果
Entry --> Caller : 返回完成结果
@enduml
