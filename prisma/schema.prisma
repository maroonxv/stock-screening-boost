// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id                                String                             @id @default(cuid())
    name                              String?
    email                             String?                            @unique
    emailVerified                     DateTime?
    image                             String?
    accounts                          Account[]
    sessions                          Session[]
    posts                             Post[]
    screeningWorkspaces               ScreeningWorkspace[]
    screeningFormulas                 ScreeningFormula[]
    researchReminders                 ResearchReminder[]
    watchLists                        WatchList[]
    timingSignalSnapshots             TimingSignalSnapshot[]
    timingAnalysisCards               TimingAnalysisCard[]
    portfolioSnapshots                PortfolioSnapshot[]
    timingRecommendations             TimingRecommendation[]
    timingReviewRecords               TimingReviewRecord[]
    timingPresets                     TimingPreset[]
    timingFeedbackObservations        TimingFeedbackObservation[]
    timingPresetAdjustmentSuggestions TimingPresetAdjustmentSuggestion[]
    workflowRuns                      WorkflowRun[]
    researchSpaces                    ResearchSpace[]
    marketContextSnapshot             MarketContextSnapshot?
}

enum MarketContextRefreshSource {
    INITIAL
    MANUAL
    AUTO
}

model MarketContextSnapshot {
    id                      String                     @id @default(cuid())
    userId                  String                     @unique
    snapshotJson            Json
    snapshotAsOf            String
    lastSuccessfulRefreshAt DateTime?
    lastRefreshAttemptAt    DateTime
    lastRefreshError        String?
    lastRefreshSource       MarketContextRefreshSource
    lastAutoRefreshDate     String?
    createdAt               DateTime                   @default(now())
    updatedAt               DateTime                   @updatedAt

    user                    User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([lastAutoRefreshDate, updatedAt])
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model ScreeningWorkspace {
    id             String   @id @default(cuid())
    userId         String
    name           String
    description    String?
    stockCodes     String[] @default([])
    indicatorIds   String[] @default([])
    formulaIds     String[] @default([])
    timeConfig     Json
    filterRules    Json
    sortState      Json?
    columnState    Json
    resultSnapshot Json?
    lastFetchedAt  DateTime?
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, updatedAt])
    @@index([userId, createdAt])
    @@index([userId, name])
}

model ScreeningFormula {
    id               String   @id @default(cuid())
    userId           String
    name             String
    expression       String
    targetIndicators Json
    description      String?
    categoryId       String
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, updatedAt])
    @@unique([userId, name])
}

model WatchList {
    id                    String   @id @default(cuid())
    name                  String
    description           String?
    stocks                Json     @default("[]")
    createdAt             DateTime @default(now())
    updatedAt             DateTime @updatedAt

    userId                String
    user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    timingAnalysisCards   TimingAnalysisCard[]
    timingRecommendations TimingRecommendation[]
    spaceLinks            ResearchSpaceWatchListLink[]

    @@index([userId])
    @@index([name])
}

model ResearchSpace {
    id             String                       @id @default(cuid())
    userId         String
    name           String
    description    String?
    briefJson      Json
    createdAt      DateTime                     @default(now())
    updatedAt      DateTime                     @updatedAt

    user           User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
    runLinks       ResearchSpaceRunLink[]
    watchListLinks ResearchSpaceWatchListLink[]
    stockLinks     ResearchSpaceStockLink[]

    @@index([userId, updatedAt])
    @@index([userId, name])
}

model ResearchSpaceRunLink {
    id        String        @id @default(cuid())
    spaceId    String
    runId      String
    note       String?
    createdAt  DateTime     @default(now())

    space      ResearchSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
    run        WorkflowRun   @relation(fields: [runId], references: [id], onDelete: Cascade)

    @@unique([spaceId, runId])
    @@index([spaceId, createdAt])
    @@index([runId])
}

model ResearchSpaceWatchListLink {
    id          String         @id @default(cuid())
    spaceId      String
    watchListId  String
    createdAt    DateTime      @default(now())

    space        ResearchSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
    watchList    WatchList     @relation(fields: [watchListId], references: [id], onDelete: Cascade)

    @@unique([spaceId, watchListId])
    @@index([spaceId, createdAt])
    @@index([watchListId])
}

model ResearchSpaceStockLink {
    id         String         @id @default(cuid())
    spaceId    String
    stockCode  String
    stockName  String
    createdAt  DateTime       @default(now())

    space      ResearchSpace  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

    @@unique([spaceId, stockCode])
    @@index([spaceId, createdAt])
    @@index([stockCode])
}

enum ResearchReminderType {
    REVIEW
}

enum ResearchReminderTargetType {
    TIMING_REVIEW
}

enum ResearchReminderStatus {
    PENDING
    TRIGGERED
    CANCELLED
}

model ResearchReminder {
    id                   String                     @id @default(cuid())
    userId               String
    timingReviewRecordId String?
    stockCode            String
    reminderType         ResearchReminderType
    targetType           ResearchReminderTargetType
    scheduledAt          DateTime
    status               ResearchReminderStatus     @default(PENDING)
    payload              Json
    triggeredAt          DateTime?
    createdAt            DateTime                   @default(now())
    updatedAt            DateTime                   @updatedAt
    user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
    timingReviewRecord   TimingReviewRecord?        @relation(fields: [timingReviewRecordId], references: [id], onDelete: Cascade)

    @@unique([timingReviewRecordId, reminderType, scheduledAt])
    @@index([userId, targetType, status, scheduledAt])
    @@index([timingReviewRecordId])
}

model TimingSignalSnapshot {
    id           String    @id @default(cuid())
    userId       String
    workflowRunId String?
    stockCode    String
    stockName    String
    asOfDate     DateTime
    sourceType   String
    sourceId     String
    timeframe    String    @default("DAILY")
    barsCount    Int
    bars         Json?
    indicators   Json
    signalContext Json
    createdAt    DateTime  @default(now())

    user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    workflowRun  WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
    analysisCards TimingAnalysisCard[]

    @@index([userId, createdAt])
    @@index([workflowRunId])
    @@index([userId, stockCode, asOfDate])
    @@index([sourceType, sourceId])
}

model TimingAnalysisCard {
    id                String    @id @default(cuid())
    userId            String
    workflowRunId     String?
    watchListId       String?
    presetId          String?
    stockCode         String
    stockName         String
    sourceType        String
    sourceId          String
    signalSnapshotId  String
    actionBias        String
    confidence        Float
    marketState       String?
    marketTransition  String?
    summary           String
    triggerNotes      String[]
    invalidationNotes String[]
    riskFlags         String[]
    reasoning         Json
    createdAt         DateTime  @default(now())
    updatedAt         DateTime  @updatedAt

    user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
    workflowRun      WorkflowRun?         @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
    watchList        WatchList?           @relation(fields: [watchListId], references: [id], onDelete: SetNull)
    preset           TimingPreset?        @relation(fields: [presetId], references: [id], onDelete: SetNull)
    signalSnapshot   TimingSignalSnapshot @relation(fields: [signalSnapshotId], references: [id], onDelete: Cascade)
    reviewRecords    TimingReviewRecord[]

    @@index([userId, createdAt])
    @@index([workflowRunId])
    @@index([watchListId, createdAt])
    @@index([presetId])
    @@index([signalSnapshotId])
    @@index([userId, stockCode, createdAt])
    @@index([sourceType, sourceId])
}

model PortfolioSnapshot {
    id              String   @id @default(cuid())
    userId          String
    name            String
    baseCurrency    String   @default("CNY")
    cash            Float
    totalCapital    Float
    positions       Json
    riskPreferences Json
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    user                   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
    timingRecommendations  TimingRecommendation[]

    @@index([userId, updatedAt])
    @@index([userId, name])
}

model TimingRecommendation {
    id                  String   @id @default(cuid())
    userId              String
    workflowRunId       String?
    portfolioSnapshotId String
    watchListId         String
    presetId            String?
    stockCode           String
    stockName           String
    action              String
    priority            Int
    confidence          Float
    suggestedMinPct     Float
    suggestedMaxPct     Float
    riskBudgetPct       Float
    marketState         String
    marketTransition    String
    riskFlags           String[]
    reasoning           Json
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt

    user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
    workflowRun       WorkflowRun?      @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
    portfolioSnapshot PortfolioSnapshot @relation(fields: [portfolioSnapshotId], references: [id], onDelete: Cascade)
    watchList         WatchList         @relation(fields: [watchListId], references: [id], onDelete: Cascade)
    preset            TimingPreset?     @relation(fields: [presetId], references: [id], onDelete: SetNull)
    reviewRecords     TimingReviewRecord[]
    feedbackObservations TimingFeedbackObservation[]

    @@index([userId, createdAt])
    @@index([workflowRunId])
    @@index([portfolioSnapshotId, createdAt])
    @@index([watchListId, createdAt])
    @@index([presetId])
    @@index([userId, stockCode, createdAt])
}

enum TimingReviewHorizon {
    T5
    T10
    T20
}

model TimingReviewRecord {
    id                        String               @id @default(cuid())
    userId                    String
    analysisCardId            String?
    recommendationId          String?
    stockCode                 String
    stockName                 String
    sourceAsOfDate            DateTime
    reviewHorizon             TimingReviewHorizon
    scheduledAt               DateTime
    completedAt               DateTime?
    expectedAction            String
    actualReturnPct           Float?
    maxFavorableExcursionPct  Float?
    maxAdverseExcursionPct    Float?
    verdict                   String?
    reviewSummary             String?
    createdAt                 DateTime             @default(now())
    updatedAt                 DateTime             @updatedAt

    user                      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
    analysisCard              TimingAnalysisCard?  @relation(fields: [analysisCardId], references: [id], onDelete: Cascade)
    recommendation            TimingRecommendation? @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
    reminders                 ResearchReminder[]
    feedbackObservation       TimingFeedbackObservation?

    @@index([userId, scheduledAt, completedAt])
    @@index([analysisCardId])
    @@index([recommendationId])
    @@index([stockCode, scheduledAt])
}

model TimingPreset {
    id                    String                 @id @default(cuid())
    userId                String
    name                  String
    description           String?
    config                Json
    createdAt             DateTime               @default(now())
    updatedAt             DateTime               @updatedAt

    user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
    timingAnalysisCards   TimingAnalysisCard[]
    timingRecommendations TimingRecommendation[]
    feedbackObservations  TimingFeedbackObservation[]
    adjustmentSuggestions TimingPresetAdjustmentSuggestion[]

    @@index([userId, updatedAt])
    @@unique([userId, name])
}

model TimingMarketContextSnapshot {
    id             String   @id @default(cuid())
    asOfDate       DateTime @unique
    state          String
    transition     String
    persistenceDays Int
    snapshotJson   Json
    analysisJson   Json
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    @@index([asOfDate])
    @@index([state, updatedAt])
}

model TimingFeedbackObservation {
    id                       String   @id @default(cuid())
    userId                   String
    reviewRecordId           String   @unique
    recommendationId         String?
    presetId                 String?
    stockCode                String
    stockName                String
    observedAt               DateTime
    sourceAsOfDate           DateTime
    reviewHorizon            TimingReviewHorizon
    expectedAction           String
    signalContext            Json
    marketContext            Json?
    positionContext          Json?
    actualReturnPct          Float
    maxFavorableExcursionPct Float
    maxAdverseExcursionPct   Float
    verdict                  String
    createdAt                DateTime @default(now())
    updatedAt                DateTime @updatedAt

    user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
    reviewRecord    TimingReviewRecord    @relation(fields: [reviewRecordId], references: [id], onDelete: Cascade)
    recommendation  TimingRecommendation? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)
    preset          TimingPreset?         @relation(fields: [presetId], references: [id], onDelete: SetNull)

    @@index([userId, createdAt])
    @@index([presetId, createdAt])
    @@index([recommendationId])
}

model TimingPresetAdjustmentSuggestion {
    id          String   @id @default(cuid())
    userId      String
    presetId    String?
    kind        String
    status      String
    title       String
    summary     String
    patch       Json
    metrics     Json
    appliedAt   DateTime?
    dismissedAt DateTime?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    preset      TimingPreset? @relation(fields: [presetId], references: [id], onDelete: SetNull)

    @@index([userId, createdAt])
    @@index([presetId, status, createdAt])
}

enum WorkflowRunStatus {
    PENDING
    RUNNING
    PAUSED
    SUCCEEDED
    FAILED
    CANCELLED
}

enum WorkflowNodeRunStatus {
    PENDING
    RUNNING
    SUCCEEDED
    FAILED
    SKIPPED
}

enum WorkflowEventType {
    RUN_CREATED
    RUN_STARTED
    RUN_PAUSED
    RUN_RESUMED
    RUN_CANCEL_REQUESTED
    RUN_CANCELLED
    RUN_SUCCEEDED
    RUN_FAILED
    NODE_STARTED
    NODE_PROGRESS
    NODE_SUCCEEDED
    NODE_FAILED
}

model WorkflowTemplate {
    id          String        @id @default(cuid())
    code        String
    version     Int
    graphConfig Json
    inputSchema Json
    isActive    Boolean       @default(true)
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt
    runs        WorkflowRun[]

    @@unique([code, version])
    @@index([code, isActive])
}

model WorkflowRun {
    id                      String             @id @default(cuid())
    templateId              String
    userId                  String
    query                   String
    input                   Json
    status                  WorkflowRunStatus  @default(PENDING)
    progressPercent         Int                @default(0)
    currentNodeKey          String?
    checkpointKey           String?
    cancellationRequestedAt DateTime?
    idempotencyKey          String?
    result                  Json?
    errorCode               String?
    errorMessage            String?
    startedAt               DateTime?
    completedAt             DateTime?
    createdAt               DateTime           @default(now())
    updatedAt               DateTime           @updatedAt
    template                WorkflowTemplate   @relation(fields: [templateId], references: [id], onDelete: Restrict)
    user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    nodeRuns                WorkflowNodeRun[]
    events                  WorkflowEvent[]
    timingSignalSnapshots   TimingSignalSnapshot[]
    timingAnalysisCards     TimingAnalysisCard[]
    timingRecommendations   TimingRecommendation[]
    spaceLinks              ResearchSpaceRunLink[]

    @@index([templateId])
    @@index([userId, createdAt])
    @@index([userId, idempotencyKey])
    @@index([status, createdAt])
}

model WorkflowNodeRun {
    id           String                @id @default(cuid())
    runId        String
    nodeKey      String
    agentName    String
    attempt      Int                   @default(1)
    status       WorkflowNodeRunStatus @default(PENDING)
    input        Json?
    output       Json?
    errorCode    String?
    errorMessage String?
    durationMs   Int?
    startedAt    DateTime?
    completedAt  DateTime?
    createdAt    DateTime              @default(now())
    updatedAt    DateTime              @updatedAt
    run          WorkflowRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
    events       WorkflowEvent[]

    @@unique([runId, nodeKey, attempt])
    @@index([runId, status])
}

model WorkflowEvent {
    id         String            @id @default(cuid())
    runId      String
    nodeRunId  String?
    sequence   Int
    eventType  WorkflowEventType
    payload    Json
    occurredAt DateTime
    createdAt  DateTime          @default(now())
    run        WorkflowRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
    nodeRun    WorkflowNodeRun?  @relation(fields: [nodeRunId], references: [id], onDelete: SetNull)

    @@unique([runId, sequence])
    @@index([runId, occurredAt])
}
